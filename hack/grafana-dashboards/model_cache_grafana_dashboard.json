{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": "-- Grafana --",
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "graphTooltip": 1,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "id": 100,
      "title": "Model Cache Performance Overview",
      "type": "row"
    },
    {
      "datasource": "${datasource}",
      "description": "Time spent in init containers downloading model weights from Akamai Object Storage cache. Computed as the difference between main container start and pod creation time. Lower = faster download.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 30
              },
              {
                "color": "red",
                "value": 120
              }
            ]
          },
          "unit": "s"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 6,
        "w": 8,
        "x": 0,
        "y": 1
      },
      "id": 1,
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "horizontal",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "auto"
      },
      "title": "OBJ Cache Download Time (Init Container)",
      "type": "stat",
      "targets": [
        {
          "datasource": "${datasource}",
          "expr": "max(\n  container_start_time_seconds{pod=~\"ray-serve-minimax.*worker.*\", container=\"ray-worker\"}\n) - max(\n  kube_pod_start_time{pod=~\"ray-serve-minimax.*worker.*\"}\n)",
          "legendFormat": "MiniMax M2.5 (4\u00d7GPU)",
          "refId": "A"
        },
        {
          "datasource": "${datasource}",
          "expr": "max(\n  container_start_time_seconds{pod=~\"ray-serve-nemotron-parse.*worker.*\", container=\"ray-worker\"}\n) - max(\n  kube_pod_start_time{pod=~\"ray-serve-nemotron-parse.*worker.*\"}\n)",
          "legendFormat": "Nemotron Parse v1.2",
          "refId": "B"
        }
      ]
    },
    {
      "datasource": "${datasource}",
      "description": "Time for the Ray Serve replica to initialize \u2014 this includes loading model weights from disk into GPU memory, compiling CUDA graphs, and running initial health checks. With object storage cache, model files are already on local disk so this phase loads directly without network download.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 120
              },
              {
                "color": "red",
                "value": 600
              }
            ]
          },
          "unit": "s"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 6,
        "w": 8,
        "x": 8,
        "y": 1
      },
      "id": 2,
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "horizontal",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "auto"
      },
      "title": "Model Load Time (GPU Initialization)",
      "type": "stat",
      "targets": [
        {
          "datasource": "${datasource}",
          "expr": "max(ray_serve_replica_initialization_latency_ms_sum{deployment=~\"LLMServer.*\",application=\"minimax\"})\n/ max(ray_serve_replica_initialization_latency_ms_count{deployment=~\"LLMServer.*\",application=\"minimax\"})\n/ 1000",
          "legendFormat": "MiniMax M2.5 (4\u00d7GPU)",
          "refId": "A"
        },
        {
          "datasource": "${datasource}",
          "expr": "max(ray_serve_replica_initialization_latency_ms_sum{deployment=~\"LLMServer.*\",application=\"nemotron-parse\"})\n/ max(ray_serve_replica_initialization_latency_ms_count{deployment=~\"LLMServer.*\",application=\"nemotron-parse\"})\n/ 1000",
          "legendFormat": "Nemotron Parse v1.2",
          "refId": "B"
        }
      ]
    },
    {
      "datasource": "${datasource}",
      "description": "Total time from pod creation to Ray Serve replica becoming healthy. Computed as init container download time (OBJ cache) plus Ray Serve startup time (model loading, CUDA compilation, health checks).",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 180
              },
              {
                "color": "red",
                "value": 600
              }
            ]
          },
          "unit": "s"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 6,
        "w": 8,
        "x": 16,
        "y": 1
      },
      "id": 3,
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "horizontal",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "auto"
      },
      "title": "Total Startup Time (Pod \u2192 Ready)",
      "type": "stat",
      "targets": [
        {
          "datasource": "${datasource}",
          "expr": "(\n  max(container_start_time_seconds{pod=~\"ray-serve-minimax.*worker.*\", container=\"ray-worker\"})\n  - max(kube_pod_start_time{pod=~\"ray-serve-minimax.*worker.*\"})\n)\n+\n(\n  max(ray_serve_replica_startup_latency_ms_sum{deployment=~\"LLMServer.*\",application=\"minimax\"})\n  / max(ray_serve_replica_startup_latency_ms_count{deployment=~\"LLMServer.*\",application=\"minimax\"})\n  / 1000\n)",
          "legendFormat": "MiniMax M2.5 (4\u00d7GPU)",
          "refId": "A"
        },
        {
          "datasource": "${datasource}",
          "expr": "(\n  max(container_start_time_seconds{pod=~\"ray-serve-nemotron-parse.*worker.*\", container=\"ray-worker\"})\n  - max(kube_pod_start_time{pod=~\"ray-serve-nemotron-parse.*worker.*\"})\n)\n+\n(\n  max(ray_serve_replica_startup_latency_ms_sum{deployment=~\"LLMServer.*\",application=\"nemotron-parse\"})\n  / max(ray_serve_replica_startup_latency_ms_count{deployment=~\"LLMServer.*\",application=\"nemotron-parse\"})\n  / 1000\n)",
          "legendFormat": "Nemotron Parse v1.2",
          "refId": "B"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 7
      },
      "id": 101,
      "title": "Startup Phase Breakdown",
      "type": "row"
    },
    {
      "datasource": "${datasource}",
      "description": "Breakdown of startup phases for MiniMax M2.5 service (4\u00d7GPU, tensor_parallel_size=4). Shows how much time is spent in object storage cache download (init container) vs model GPU loading vs total startup. The cache download phase should be a small fraction of total.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "axisBorderShow": false,
            "axisCenteredZero": false,
            "axisLabel": "Duration",
            "fillOpacity": 80,
            "gradientMode": "none",
            "hideFrom": {
              "legend": false,
              "tooltip": false,
              "viz": false
            },
            "lineWidth": 1,
            "scaleDistribution": {
              "type": "linear"
            }
          },
          "mappings": [],
          "unit": "s"
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "OBJ Download"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "blue",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Model Load (GPU)"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "orange",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Total Startup"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "green",
                  "mode": "fixed"
                }
              }
            ]
          }
        ]
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 8
      },
      "id": 4,
      "options": {
        "barRadius": 0.1,
        "barWidth": 0.7,
        "fullHighlight": false,
        "groupWidth": 0.7,
        "legend": {
          "calcs": [],
          "displayMode": "list",
          "placement": "bottom"
        },
        "orientation": "horizontal",
        "showValue": "always",
        "stacking": "none",
        "tooltip": {
          "mode": "single",
          "sort": "none"
        },
        "xTickLabelRotation": 0
      },
      "title": "MiniMax M2.5 \u2014 Startup Phase Breakdown",
      "type": "barchart",
      "targets": [
        {
          "datasource": "${datasource}",
          "expr": "max(\n  container_start_time_seconds{pod=~\"ray-serve-minimax.*worker.*\", container=\"ray-worker\"}\n) - max(\n  kube_pod_start_time{pod=~\"ray-serve-minimax.*worker.*\"}\n)",
          "legendFormat": "OBJ Download",
          "instant": true,
          "refId": "A"
        },
        {
          "datasource": "${datasource}",
          "expr": "max(ray_serve_replica_initialization_latency_ms_sum{deployment=~\"LLMServer.*\",application=\"minimax\"})\n/ max(ray_serve_replica_initialization_latency_ms_count{deployment=~\"LLMServer.*\",application=\"minimax\"})\n/ 1000",
          "legendFormat": "Model Load (GPU)",
          "instant": true,
          "refId": "B"
        },
        {
          "datasource": "${datasource}",
          "expr": "max(ray_serve_replica_startup_latency_ms_sum{deployment=~\"LLMServer.*\",application=\"minimax\"})\n/ max(ray_serve_replica_startup_latency_ms_count{deployment=~\"LLMServer.*\",application=\"minimax\"})\n/ 1000",
          "legendFormat": "Total Startup",
          "instant": true,
          "refId": "C"
        }
      ]
    },
    {
      "datasource": "${datasource}",
      "description": "Breakdown of startup phases for Nemotron Parse v1.2 (OCR) service. Shows how much time is spent in object storage cache download (init container) vs model GPU loading vs total startup.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "axisBorderShow": false,
            "axisCenteredZero": false,
            "axisLabel": "Duration",
            "fillOpacity": 80,
            "gradientMode": "none",
            "hideFrom": {
              "legend": false,
              "tooltip": false,
              "viz": false
            },
            "lineWidth": 1,
            "scaleDistribution": {
              "type": "linear"
            }
          },
          "mappings": [],
          "unit": "s"
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "OBJ Download"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "blue",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Model Load (GPU)"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "orange",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Total Startup"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "green",
                  "mode": "fixed"
                }
              }
            ]
          }
        ]
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 8
      },
      "id": 5,
      "options": {
        "barRadius": 0.1,
        "barWidth": 0.7,
        "fullHighlight": false,
        "groupWidth": 0.7,
        "legend": {
          "calcs": [],
          "displayMode": "list",
          "placement": "bottom"
        },
        "orientation": "horizontal",
        "showValue": "always",
        "stacking": "none",
        "tooltip": {
          "mode": "single",
          "sort": "none"
        },
        "xTickLabelRotation": 0
      },
      "title": "Nemotron Parse v1.2 \u2014 Startup Phase Breakdown",
      "type": "barchart",
      "targets": [
        {
          "datasource": "${datasource}",
          "expr": "max(\n  container_start_time_seconds{pod=~\"ray-serve-nemotron-parse.*worker.*\", container=\"ray-worker\"}\n) - max(\n  kube_pod_start_time{pod=~\"ray-serve-nemotron-parse.*worker.*\"}\n)",
          "legendFormat": "OBJ Download",
          "instant": true,
          "refId": "A"
        },
        {
          "datasource": "${datasource}",
          "expr": "max(ray_serve_replica_initialization_latency_ms_sum{deployment=~\"LLMServer.*\",application=\"nemotron-parse\"})\n/ max(ray_serve_replica_initialization_latency_ms_count{deployment=~\"LLMServer.*\",application=\"nemotron-parse\"})\n/ 1000",
          "legendFormat": "Model Load (GPU)",
          "instant": true,
          "refId": "B"
        },
        {
          "datasource": "${datasource}",
          "expr": "max(ray_serve_replica_startup_latency_ms_sum{deployment=~\"LLMServer.*\",application=\"nemotron-parse\"})\n/ max(ray_serve_replica_startup_latency_ms_count{deployment=~\"LLMServer.*\",application=\"nemotron-parse\"})\n/ 1000",
          "legendFormat": "Total Startup",
          "instant": true,
          "refId": "C"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 16
      },
      "id": 102,
      "title": "Cache Efficiency",
      "type": "row"
    },
    {
      "datasource": "${datasource}",
      "description": "Percentage of total startup time spent downloading from object storage cache. Lower % means the cache download is a small fraction = cache is fast relative to model initialization.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "max": 100,
          "min": 0,
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 30
              },
              {
                "color": "red",
                "value": 60
              }
            ]
          },
          "unit": "percent"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 6,
        "w": 8,
        "x": 0,
        "y": 17
      },
      "id": 6,
      "options": {
        "minVizHeight": 75,
        "minVizWidth": 75,
        "orientation": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "showThresholdLabels": false,
        "showThresholdMarkers": true,
        "sizing": "auto"
      },
      "title": "OBJ Download % of Total Startup \u2014 MiniMax",
      "type": "gauge",
      "targets": [
        {
          "datasource": "${datasource}",
          "expr": "(\n  max(container_start_time_seconds{pod=~\"ray-serve-minimax.*worker.*\", container=\"ray-worker\"})\n  - max(kube_pod_start_time{pod=~\"ray-serve-minimax.*worker.*\"})\n)\n/ (\n  max(ray_serve_replica_startup_latency_ms_sum{deployment=~\"LLMServer.*\",application=\"minimax\"})\n  / max(ray_serve_replica_startup_latency_ms_count{deployment=~\"LLMServer.*\",application=\"minimax\"})\n  / 1000\n) * 100",
          "legendFormat": "MiniMax Cache %",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": "${datasource}",
      "description": "Percentage of total startup time spent downloading from object storage cache for Nemotron Parse service.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "max": 100,
          "min": 0,
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 30
              },
              {
                "color": "red",
                "value": 60
              }
            ]
          },
          "unit": "percent"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 6,
        "w": 8,
        "x": 8,
        "y": 17
      },
      "id": 7,
      "options": {
        "minVizHeight": 75,
        "minVizWidth": 75,
        "orientation": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "showThresholdLabels": false,
        "showThresholdMarkers": true,
        "sizing": "auto"
      },
      "title": "OBJ Download % of Total Startup \u2014 Nemotron",
      "type": "gauge",
      "targets": [
        {
          "datasource": "${datasource}",
          "expr": "(\n  max(container_start_time_seconds{pod=~\"ray-serve-nemotron-parse.*worker.*\", container=\"ray-worker\"})\n  - max(kube_pod_start_time{pod=~\"ray-serve-nemotron-parse.*worker.*\"})\n)\n/ (\n  max(ray_serve_replica_startup_latency_ms_sum{deployment=~\"LLMServer.*\",application=\"nemotron-parse\"})\n  / max(ray_serve_replica_startup_latency_ms_count{deployment=~\"LLMServer.*\",application=\"nemotron-parse\"})\n  / 1000\n) * 100",
          "legendFormat": "Nemotron Cache %",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": "${datasource}",
      "description": "Average network throughput during init containers. Uses actual bytes received (container_network_receive_bytes_total) divided by init duration (main container start − pod start). Includes model download, s5cmd install, and any pip cache warmup.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "yellow",
                "value": 500
              },
              {
                "color": "green",
                "value": 2000
              }
            ]
          },
          "unit": "MBs"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 6,
        "w": 8,
        "x": 16,
        "y": 17
      },
      "id": 8,
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "horizontal",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "auto"
      },
      "title": "Init Container Throughput",
      "type": "stat",
      "targets": [
        {
          "datasource": "${datasource}",
          "expr": "max(container_network_receive_bytes_total{pod=~\"ray-serve-minimax.*worker.*\"})\n/ 1048576\n/ (\n  max(container_start_time_seconds{pod=~\"ray-serve-minimax.*worker.*\", container=\"ray-worker\"})\n  - max(kube_pod_start_time{pod=~\"ray-serve-minimax.*worker.*\"})\n)",
          "legendFormat": "MiniMax",
          "refId": "A"
        },
        {
          "datasource": "${datasource}",
          "expr": "max(container_network_receive_bytes_total{pod=~\"ray-serve-nemotron-parse.*worker.*\"})\n/ 1048576\n/ (\n  max(container_start_time_seconds{pod=~\"ray-serve-nemotron-parse.*worker.*\", container=\"ray-worker\"})\n  - max(kube_pod_start_time{pod=~\"ray-serve-nemotron-parse.*worker.*\"})\n)",
          "legendFormat": "Nemotron",
          "refId": "B"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 23
      },
      "id": 103,
      "title": "Ray Serve Replica Health",
      "type": "row"
    },
    {
      "datasource": "${datasource}",
      "description": "Ray Serve replica initialization latency over time. Shows how long each replica took to initialize (constructor + health check). Spikes indicate new replicas being created (e.g., scaling events, restarts).",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "axisBorderShow": false,
            "axisCenteredZero": false,
            "axisLabel": "",
            "drawStyle": "line",
            "fillOpacity": 20,
            "gradientMode": "scheme",
            "hideFrom": {
              "legend": false,
              "tooltip": false,
              "viz": false
            },
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "pointSize": 8,
            "scaleDistribution": {
              "type": "linear"
            },
            "showPoints": "always",
            "spanNulls": false,
            "stacking": {
              "group": "A",
              "mode": "none"
            },
            "thresholdsStyle": {
              "mode": "off"
            }
          },
          "mappings": [],
          "unit": "s"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 24
      },
      "id": 9,
      "options": {
        "legend": {
          "calcs": [
            "lastNotNull"
          ],
          "displayMode": "table",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "title": "Replica Initialization Latency Over Time",
      "type": "timeseries",
      "targets": [
        {
          "datasource": "${datasource}",
          "expr": "max by (application) (\n  ray_serve_replica_initialization_latency_ms_sum{deployment!=\"OpenAiIngress\"}\n  / ray_serve_replica_initialization_latency_ms_count{deployment!=\"OpenAiIngress\"}\n) / 1000",
          "legendFormat": "{{application}}",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": "${datasource}",
      "description": "Health check latency for each Ray Serve deployment. Higher values may indicate model or GPU issues.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "axisBorderShow": false,
            "axisCenteredZero": false,
            "axisLabel": "",
