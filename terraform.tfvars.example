# ============================================================================
# REQUIRED VARIABLES
# ============================================================================
# Copy this file to terraform.tfvars and fill in your actual values
# Note: HuggingFace token and API key are now configured in .env for Tilt

linode_token       = "your-linode-api-token-here"

# ============================================================================
# CLUSTER CONFIGURATION
# ============================================================================

cluster_label      = "myllm"
kubernetes_version = "1.34"
region             = "us-sea"

# GPU Node Pool Configuration
# 4-GPU node for MiniMax M2.5 NVFP4 (2× TP=2 replicas)
gpu_big_node_type  = "g3-gpu-rtxpro6000-blackwell-4"
gpu_big_node_count = 1

# 2-GPU nodes for Nemotron Parse (MIG-partitioned: 4× 1g.24gb per GPU = 8 per node)
gpu_node_type      = "g3-gpu-rtxpro6000-blackwell-2"
gpu_node_count     = 2

# Resource tags for organization and cost tracking
tags = ["kuberay", "llm", "gpu", "terraform"]

