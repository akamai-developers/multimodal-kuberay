# ============================================================================
# Tilt Environment Configuration
# ============================================================================
# Copy this file to .env and fill in your actual values
# DO NOT commit .env to git (it's in .gitignore)

HUGGINGFACE_TOKEN=hf_your_token_here

OPENAI_API_KEY=test_secret_123

# ============================================================================
# Object Storage Configuration (for model weight caching)
# ============================================================================
# Linode Object Storage credentials — used by the model-upload Job
# and init containers to cache/fetch model weights from S3.

S3_ENDPOINT_HOSTNAME=us-ord-1.linodeobjects.com
OBJ_REGION=us-ord-1
OBJ_ACCESS_KEY=your-access-key-here
OBJ_SECRET_KEY=your-secret-key-here
MODEL_BUCKET=model-cache
